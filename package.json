{
  "name": "securekern-site",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npx @11ty/eleventy --incremental",
    "build:ci": "node scripts/clean.mjs && npx @11ty/eleventy",
    "build:no-clean": "npx @11ty/eleventy",
    "build:preview": "node scripts/build-preview.mjs",
    "build:retry": "node scripts/clean-retry.mjs && npx @11ty/eleventy --incremental && node scripts/verify-assets.mjs",
    "test:assets": "node scripts/verify-assets.mjs",
    "clean": "node scripts/clean.mjs",
    "dev": "eleventy --serve --watch",
    "serve": "npx -y serve Website",
    "preview": "npm run build && npx -y serve Website",
    "cms": "decap-server"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "decap-server": "^3.5.0",
    "markdown-it": "^14.1.0",
    "sharp": "^0.34.5"
  }
}
