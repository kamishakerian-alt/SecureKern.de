<header class="header">
  <div class="container">
    <nav class="nav" aria-label="{{ nav.label or 'Main navigation' }}">
      <a href="{{ nav.logo.href }}" class="nav__logo" aria-label="{{ nav.logo.label }}">
        <img src="{{ nav.logo.src }}" alt="{{ nav.logo.alt }}" />
      </a>

      <button
        class="nav__hamburger"
        type="button"
        aria-label="{{ nav.mobile_menu_toggle.label }}"
        aria-expanded="false"
        aria-controls="nav-menu"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>

      <div class="nav__menu-container" id="nav-menu">
        <ul class="nav__menu">
          {% for item in nav.main %}
            <li class="nav__item {% if item.children %}nav__item--has-dropdown{% endif %}">
              <a
                href="{{ item.href }}"
                class="nav__link"
                {% if item.children %}
                aria-haspopup="true"
                aria-expanded="false"
                aria-controls="dropdown-{{ loop.index }}"
                {% endif %}
              >
                {{ item.label }}
                {% if item.children %}<i class="fas fa-chevron-down" aria-hidden="true"></i>{% endif %}
              </a>
              {% if item.children %}
                <ul class="nav__dropdown" id="dropdown-{{ loop.index }}">
                  {% for child in item.children %}
                    <li><a href="{{ child.href }}" class="nav__dropdown-link">{{ child.label }}</a></li>
                  {% endfor %}
                </ul>
              {% endif %}
            </li>
          {% endfor %}
        </ul>

        <div class="nav__actions">
          <a href="{{ site_local.cta.href }}" class="btn btn--primary">{{ site_local.cta.label }}</a>

          {% if isEn %}
            {% set currentLang = 'en' %}
            {% set targetLang = 'de' %}
            {% set targetHref = page.url | replace('/en', '') %}
          {% else %}
            {% set currentLang = 'de' %}
            {% set targetLang = 'en' %}
            {% set targetHref = '/en' + (page.url or '/') %}
          {% endif %}

          <a href="{{ targetHref }}" class="nav__lang-toggle" aria-label="{{ nav.language_toggle.label }}">
            <img src="{{ nav.language_toggle[targetLang].flag }}" alt="{{ nav.language_toggle[targetLang].alt }}" />
            <span class="nav__lang-label">{{ nav.language_toggle[targetLang].label }}</span>
          </a>
        </div>
      </div>
    </nav>
  </div>
</header>
