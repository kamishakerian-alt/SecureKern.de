<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      {% for column in nav.footer %}
        <div class="footer-column">
          <h4>{{ column.title }}</h4>
          <ul>
            {% for item in column.links %}
              <li><a href="{{ item.href }}">{{ item.label }}</a></li>
            {% endfor %}
          </ul>
        </div>
      {% endfor %}

      <div class="footer-column">
        <h4>{{ site_local.contact.title }}</h4>
        <p>
          {{ site_local.address.company }}<br />
          {{ site_local.address.street }}<br />
          {{ site_local.address.zipCity }}<br />
          <a href="mailto:{{ site_local.contact.email }}">{{ site_local.contact.email }}</a>
        </p>
      </div>
    </div>

    <div class="footer-bottom">
      <a href="{{ nav.logo.href }}" class="footer-logo-type">Secure<span>Kern</span></a>
      <div class="footer-socials">
        {% for social in site_local.socials %}
          <a href="{{ social.href }}" target="_blank" rel="noopener" title="{{ social.title }}" aria-label="{{ social.title }}"><i class="fab fa-{{ social.icon }}"></i></a>
        {% endfor %}
      </div>
      <p>&copy; {{ meta.year }} {{ site_local.copyright }}</p>
    </div>
  </div>
</footer>

