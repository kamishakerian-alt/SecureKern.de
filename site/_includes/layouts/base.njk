<!doctype html>
{%- set isEn = (page.url and ('/en/' in page.url)) or (page.lang == 'en') -%}
{% if isEn %}
  {% set site_local = site['en'] %}
  {% set nav = navigation['en'] %}
{% else %}
  {% set site_local = site['de'] %}
  {% set nav = navigation['de'] %}
{% endif %}
<html lang="{{ site_local.lang or 'de' }}">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{{ title }} | {{ site_local.title }}</title>
    {% if description %}<meta name="description" content="{{ description }}" />{% endif %}
    <link rel="canonical" href="{{ site_local.baseUrl }}{{ page.url }}" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="{{ site_local.title }}" />
    <meta property="og:title" content="{{ title }} | {{ site_local.title }}" />
    {% if description %}<meta property="og:description" content="{{ description }}" />{% endif %}
    <meta property="og:url" content="{{ site_local.baseUrl }}{{ page.url }}" />
    <meta property="og:image" content="{{ site.de.baseUrl }}/assets/images/visual-assets/og-image.jpg" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ title }} | {{ site_local.title }}" />
    {% if description %}<meta name="twitter:description" content="{{ description }}" />{% endif %}
    <meta name="twitter:image" content="{{ site.de.baseUrl }}/assets/images/visual-assets/og-image.jpg" />

    <link rel="icon" type="image/svg+xml" href="/assets/images/brand/logo-primary.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="/assets/css/main.css" />
  </head>
  <body>
    {% include "partials/header.njk" %}

    <main id="main-content">
      {{ content | safe }}
    </main>

    {% include "partials/footer.njk" %}

    <script src="/assets/js/main.js" defer></script>
  </body>
</html>
